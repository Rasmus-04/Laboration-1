<Window x:Class="Laboration_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laboration_1"
        xmlns:MenuBar="clr-namespace:Laboration_1.Vy.MenuBar"
        xmlns:MemberList="clr-namespace:Laboration_1.Vy.MedlemarVy"
        xmlns:AllaSpelVy="clr-namespace:Laboration_1.Vy.SpelVy"
        
        mc:Ignorable="d"
        Title="Laboration 1 Grupp 8" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        
        <MenuBar:MenuBar Grid.Row="0" />
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <MemberList:MedlemarVy Grid.Column="0"/>
            <AllaSpelVy:SpelVy Grid.Column="1"/>

        </Grid>
        
        <StackPanel Orientation="Horizontal" Grid.Row="2">
            <Button Content="Ta Bort Medlem" Name="removeUserBtn" Margin="10" Click="removeUserBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
