<Window x:Class="Laboration_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laboration_1"
        mc:Ignorable="d"
        Title="Laboration 1 Grupp 8" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Name="AddUser" Content="Lägg till användare" Margin="5" Height="30"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <ListView ItemsSource="{Binding Members}" Name="lvMembers" Grid.Row="1" SelectionMode="Single">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="50"/>
                        <GridViewColumn Header="Age" DisplayMemberBinding="{Binding Age}" Width="50"/>
                        <GridViewColumn Header="Email" DisplayMemberBinding="{Binding Email}" Width="50"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Grid.Row="1" Grid.Column="1">
                <Label Content="Namn"/>
                <TextBox Name="txtName" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                <Label Content="Ålder"/>
                <TextBox Name="txtAge" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                <Label Content="Epost"/>
                <TextBox Name="txtEmail" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0"/>

                <Button Content="Lägg Till" Margin="10" Click="AddNewUser"/>
            </StackPanel>
        </Grid>
        <Button Content="Ta bort användare" Grid.Row="2" Margin="5" Height="30" Width="150" HorizontalAlignment="Left" Click="Button_Click"/>
    </Grid>
</Window>
